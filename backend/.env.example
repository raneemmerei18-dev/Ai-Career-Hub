# ============================================================================
# AI CAREER HUB - BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and update the values for your environment

# Environment Setup
ENVIRONMENT=development
DEBUG=true
APP_NAME=AI Career Hub

# ============================================================================
# DATABASE CONFIGURATION (MySQL/MariaDB)
# ============================================================================
# Format: mysql+aiomysql://user:password@host:port/database
# Default port: 3306
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/ai_career_hub
DATABASE_ECHO=false

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
SECRET_KEY=your-super-secret-key-minimum-32-characters-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# REDIS CONFIGURATION (Optional)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
GROQ_API_KEY=
DEFAULT_AI_PROVIDER=groq

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# FILE UPLOAD
# ============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=["pdf", "docx", "png", "jpg", "jpeg"]

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@aicareerhub.com

# ============================================================================
# EXTERNAL JOB APIS
# ============================================================================
ADZUNA_APP_ID=
ADZUNA_API_KEY=
JSEARCH_API_KEY=

# ============================================================================
# FILE STORAGE
# ============================================================================
VERCEL_BLOB_URL=
VERCEL_BLOB_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ============================================================================
# PAYMENT CONFIGURATION
# ============================================================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
