# ============================================================================
# AI CAREER HUB - BACKEND ENVIRONMENT CONFIGURATION (MySQL)
# ============================================================================

# Environment Setup
ENVIRONMENT=development
DEBUG=true
APP_NAME=AI Career Hub

# ============================================================================
# DATABASE CONFIGURATION (MySQL/MariaDB)
# ============================================================================
# Format: mysql+aiomysql://user:password@host:port/database
# Default MySQL port: 3306
# Connection example for phpMyAdmin/MariaDB:
DATABASE_URL=postgresql+asyncpg://postgres:raneem12$@localhost:5432/ai_career_hub
DATABASE_ECHO=false

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allow frontend origin (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate a secure secret key (min 32 characters)
SECRET_KEY=your-super-secret-key-minimum-32-characters-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# REDIS CONFIGURATION (Optional - for caching/sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================
# Groq API Key
GROQ_API_KEY=

# Default AI Provider
DEFAULT_AI_PROVIDER=groq

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=["pdf", "docx", "png", "jpg", "jpeg"]

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# For verification emails and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
FROM_EMAIL=noreply@aicareerhub.com

# ============================================================================
# EXTERNAL JOB APIS
# ============================================================================
# Adzuna Job API
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# JSearch Job API
JSEARCH_API_KEY=

# ============================================================================
# OAUTH CONFIGURATION (Google)
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/social-callback/google
FRONTEND_URL=http://localhost:3000

# ============================================================================
# FILE STORAGE (Vercel Blob or AWS S3)
# ============================================================================
VERCEL_BLOB_URL=
VERCEL_BLOB_TOKEN=

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ============================================================================
# PAYMENT CONFIGURATION (Stripe)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
